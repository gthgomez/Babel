# ─── Babel CLI — Environment Configuration ───────────────────────────────────
#
# Copy this file to .env and fill in your real keys.
# Never commit .env to version control.
#
# ─── API Keys ─────────────────────────────────────────────────────────────────

# DeepInfra (Nemotron 3 Super + Qwen3-32B — used by orchestrator/qa/executor waterfalls)
# Get your key at: https://deepinfra.com/dashboard
DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# Gemini API (used by structuredRunner repair loop)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API (structuredRunner repair loop last resort)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ─── Waterfall Control ────────────────────────────────────────────────────────

# Set to "true" to prevent any spend on API tiers (DeepInfra, Groq, Anthropic).
# The pipeline will throw if all CLI tiers (Codex, Gemini) fail.
# BABEL_DISABLE_API_FALLBACK=true

# ─── CLI Runner — Codex (Tier 1 default) ─────────────────────────────────────

# Binary name in PATH. Install: npm install -g @openai/codex
# Login (browser):  codex login
# Login (headless): codex login --device-auth
# Login (API key):  set OPENAI_API_KEY=sk-...
BABEL_CODEX_CMD=codex

# Flags passed to `codex exec` before the prompt argument.
# --skip-git-repo-check  bypasses the Git repo requirement (needed when
#                        running outside a repo, e.g. for JSON-only stages).
# --full-auto            allows Codex to make file edits autonomously.
BABEL_CODEX_ARGS=--full-auto

# API key auth alternative to `codex login` (optional).
# OPENAI_API_KEY=sk-your_openai_api_key_here

# ─── CLI Runner — Claude (Tier 2) ────────────────────────────────────────────

# Binary name in PATH (installed via: npm install -g @anthropic-ai/claude-code)
BABEL_CLAUDE_CMD=claude

# Headless/print mode flag.
BABEL_CLAUDE_ARGS=--print

# ─── CLI Runner — Gemini (Stage 1+4 primary / Stage 2+3 fallback) ────────────

# Binary name in PATH (installed via: npm install -g @google/generative-ai-cli)
BABEL_GEMINI_CMD=gemini

# Extra flags passed to the gemini command.
# Do NOT add --model here — model is injected per-stage by execute.ts.
BABEL_GEMINI_ARGS=

# Flag used to pass the prompt text.
BABEL_GEMINI_PROMPT_FLAG=-p

# ─── Gemini Per-Stage Model Selection ─────────────────────────────────────────

# Fast tier  — Stage 1 (Orchestrator) primary, Stage 4 (Executor) primary.
# Default: gemini-3.1-flash-lite-preview
BABEL_GEMINI_MODEL_FAST=gemini-3.1-flash-lite-preview

# Mid tier   — Stage 3 (QA) fallback, Stage 2 (Planning) rescue.
# Default: gemini-3-flash-preview
BABEL_GEMINI_MODEL_MID=gemini-3-flash-preview

# Pro tier   — Stage 2 (Planning) rare rescue. Requires Gemini Advanced subscription.
# Default: gemini-3.1-pro-preview
BABEL_GEMINI_MODEL_PRO=gemini-3.1-pro-preview

# ─── Shared CLI Settings ──────────────────────────────────────────────────────

# Hard timeout for any CLI runner in milliseconds. Default: 120000 (2 minutes).
# Increase if your machine is slow or prompts are very large.
# BABEL_CLI_TIMEOUT_MS=120000

# ─── DeepInfra API Settings ───────────────────────────────────────────────────

# max_tokens for DeepInfra responses (Nemotron, Qwen3). Default: 8096
# BABEL_DEEPINFRA_TOKENS=8096

# ─── Anthropic API Settings (repair loop last resort) ─────────────────────────

# Model ID for the Anthropic API tier. Default: claude-sonnet-4-6
BABEL_API_MODEL=claude-sonnet-4-6

# max_tokens for Anthropic API responses. Default: 8096
BABEL_API_TOKENS=8096

# ─── Pipeline Paths ───────────────────────────────────────────────────────────

# Absolute path to your target project root (the project Babel will work on).
# Example (Windows): BABEL_PROJECT_ROOT=/project/root/example_saas_backend
# Example (Unix):    BABEL_PROJECT_ROOT=/home/you/projects/example_saas_backend
# Leave unset or set to a specific project directory.
BABEL_PROJECT_ROOT=/path/to/your/target/project

# Path to the example_web_audit project root (required for audit_ui tool).
# Example (Windows): AUDITGUARD_ROOT=/project/root/example_web_audit
# Example (Unix):    AUDITGUARD_ROOT=/home/you/projects/example_web_audit
AUDITGUARD_ROOT=/path/to/your/example_web_audit

# Directory where evidence bundles are written.
# Leave unset to use <BABEL_ROOT>/runs/
# BABEL_RUNS_DIR=/path/to/your/runs/directory

# ─── Dynamic Routing v1 ───────────────────────────────────────────────────────
#
# When enabled, the routing engine scans recent 05_waterfall_telemetry.json
# files and reorders each stage's waterfall to start at the historically best
# tier. Safe fallback: if telemetry is thin or the run dir is empty, the
# original waterfall order is preserved.
#
# Enable:
# BABEL_DYNAMIC_ROUTING=true

# How many recent run directories to scan for telemetry. Default: 50.
# BABEL_DYNAMIC_ROUTING_MAX_RUNS=50

# Minimum stage-specific telemetry entries required before the score is
# trusted. Below this threshold the engine falls back to original order. Default: 3.
# BABEL_DYNAMIC_ROUTING_MIN_SAMPLES=3

# ─── Routing Confidence Gate (Stage 1) ───────────────────────────────────────
#
# When enabled, the pipeline reads `routing_confidence` from the Orchestrator
# manifest and applies a three-band policy:
#
#   high   (>= HIGH threshold)         — accept routing decision as-is
#   medium ([MED threshold, HIGH))     — downgrade pipeline_mode direct → verified
#   low    (< MED threshold)           — run a bounded validator pass at tier 2;
#                                        if still low, proceed with a warning
#
# The orchestrator prompt always asks for routing_confidence (the field is
# optional, so older manifests are backward-compatible). Control-flow
# changes only activate when BABEL_ROUTING_CONFIDENCE_ENABLE=true.
#
# After enough runs accumulate, use:
#   tools/report-routing-confidence.ps1
# to analyse confidence distribution and tune thresholds.
#
# Enable:
# BABEL_ROUTING_CONFIDENCE_ENABLE=true

# High-band threshold. Scores >= this are accepted without intervention. Default: 0.80
# BABEL_ROUTING_CONFIDENCE_HIGH=0.80

# Medium-band lower bound. Scores in [MED, HIGH) trigger a mode downgrade. Default: 0.60
# BABEL_ROUTING_CONFIDENCE_MEDIUM=0.60

# 0-based tier index at which the bounded validator pass starts.
# Default: 1 (skip tier 0, start at tier 1 to avoid re-running the same tier).
# BABEL_ROUTING_CONFIDENCE_VALIDATOR_TIER_INDEX=1

# ─── Execution Mode ───────────────────────────────────────────────────────────

# Set to "false" to enable LIVE tool execution (file writes, shell commands).
# Default behaviour is DRY RUN — mutating tools are logged but not executed.
BABEL_DRY_RUN=true

# ─── OpenTelemetry Tracing (Phase 1.5) ───────────────────────────────────────
#
# Tracing is DISABLED by default. Enable to export traces to a local or remote
# OTLP backend (e.g., Jaeger, Honeycomb, Grafana Tempo).
#
# Quick local setup with Jaeger:
#   docker compose -f docker-compose.jaeger.yml up -d
#   Then set BABEL_OTEL_ENABLED=true and BABEL_OTEL_EXPORTER_OTLP_ENDPOINT below.
#   View traces at: http://localhost:16686
#
# See docs/BABEL_OTEL_LOCAL_VALIDATION.md for the full developer guide.

# Set to "true" to enable trace export. Default: disabled.
# BABEL_OTEL_ENABLED=true

# OTLP HTTP endpoint for trace export. Must be set when BABEL_OTEL_ENABLED=true.
# Jaeger local default:
# BABEL_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# Honeycomb example:
# BABEL_OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io/v1/traces

# Service name shown in the trace backend UI. Default: babel-cli
# BABEL_OTEL_SERVICE_NAME=babel-cli
