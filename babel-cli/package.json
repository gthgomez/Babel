{
  "name": "babel-cli",
  "version": "0.1.0",
  "description": "Local coding agent runtime for Babel — chat, plan, and deep modes with TUI/REPL",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "babel": "bin/babel.js",
    "babel-lite": "bin/babel-lite.js",
    "bl": "bin/babel-lite.js"
  },
  "scripts": {
    "audit:pricing": "tsx --no-warnings=ExperimentalWarning scripts/audit_provider_pricing.ts",
    "audit:token-usage": "tsx --no-warnings=ExperimentalWarning scripts/audit_token_usage.ts",
    "audit:performance": "tsx --no-warnings=ExperimentalWarning scripts/audit_cli_performance.ts",
    "exercise:jit": "tsx --no-warnings=ExperimentalWarning scripts/jit_exercise.ts",
    "benchmark": "tsx --no-warnings=ExperimentalWarning scripts/governance_benchmark.ts",
    "benchmark:agent": "tsx --no-warnings=ExperimentalWarning scripts/run_agent_benchmark.ts",
    "benchmark:agent:plan": "tsx --no-warnings=ExperimentalWarning scripts/run_agent_benchmark.ts --plan --json",
    "benchmark:agent:daily": "tsx --no-warnings=ExperimentalWarning scripts/run_agent_benchmark.ts --tier A_daily --provider mock --json",
    "benchmark:agent:live": "tsx --no-warnings=ExperimentalWarning scripts/run_agent_benchmark.ts --live --tier all",
    "benchmark:agent:live:full": "tsx --no-warnings=ExperimentalWarning scripts/run_agent_benchmark.ts --full --tier all",
    "benchmark:agent:critic": "tsx --no-warnings=ExperimentalWarning scripts/remeasure_swe_a_with_critic.ts",
    "benchmark:agent:critic:a09": "tsx --no-warnings=ExperimentalWarning scripts/remeasure_swe_a_with_critic.ts --a09-acceptance",
    "benchmark:agent:provision-swebench": "node scripts/provision_swebench_dataset.mjs",
    "benchmark:parity": "node dist/index.js benchmark parity --json",
    "benchmark:production": "node dist/index.js benchmark production --json",
    "benchmark:product": "node dist/index.js benchmark product --json",
    "benchmark:cli": "tsx --no-warnings=ExperimentalWarning scripts/cli_benchmark.ts",
    "benchmark:tui": "tsx --no-warnings=ExperimentalWarning scripts/tui_benchmark.ts",
    "parity:run-babel": "tsx --no-warnings=ExperimentalWarning scripts/parity_run_babel.ts",
    "parity:merge-fixture": "tsx --no-warnings=ExperimentalWarning scripts/parity_merge_fixture.ts",
    "test:live-parity-corpus": "tsx --no-warnings=ExperimentalWarning scripts/run_live_parity_corpus.ts",
    "test:jit-veto-replay": "tsx --no-warnings=ExperimentalWarning scripts/test_jit_veto_replay.ts",
    "test:daemon": "tsx --no-warnings=ExperimentalWarning --test src/daemon/**/*.test.ts",
    "test:live-lite-discovery": "tsx --no-warnings=ExperimentalWarning scripts/run_live_lite_discovery.ts",
    "test:vagueness-benchmark": "tsx --no-warnings=ExperimentalWarning scripts/run_vagueness_benchmark.ts --provider mock",
    "test:vagueness-benchmark:live": "tsx --no-warnings=ExperimentalWarning scripts/run_vagueness_benchmark.ts --provider live",
    "test:workspace-discovery:live": "tsx --no-warnings=ExperimentalWarning scripts/run_workspace_discovery_benchmark.ts --provider live",
    "test:workspace-discovery:smoke": "tsx --no-warnings=ExperimentalWarning scripts/run_workspace_discovery_benchmark.ts --provider live --smoke",
    "benchmark:report": "tsx --no-warnings=ExperimentalWarning scripts/governance_benchmark_report.ts",
    "publish:product-metrics": "tsx --no-warnings=ExperimentalWarning scripts/publish_product_metrics.ts",
    "test:public-export-regressions": "pwsh -NoProfile -ExecutionPolicy Bypass -File ../tools/test-public-release-automation.ps1",
    "test:public-release": "pwsh -NoProfile -ExecutionPolicy Bypass -File ../tools/validate-public-release.ps1",
    "test:public-release:strict": "pwsh -NoProfile -ExecutionPolicy Bypass -File ../tools/validate-public-release.ps1 -Strict",
    "test:public-release:security": "pwsh -NoProfile -ExecutionPolicy Bypass -File ../tools/test-public-release-security.ps1 -RequireExternalScanner",
    "test:public-release:security:local": "pwsh -NoProfile -ExecutionPolicy Bypass -File ../tools/test-public-release-security.ps1",
    "test:schema-failures": "npm run test:schema-failures:unit && npm run test:schema-failures:replay",
    "test:schema-failures:replay": "node --import tsx --no-warnings=ExperimentalWarning scripts/test_schema_failures_replay.ts",
    "build": "npm run clean:dist && tsc && node scripts/copy_playbooks.mjs",
    "copy:playbooks": "node scripts/copy_playbooks.mjs",
    "clean:dist": "node scripts/clean_dist.mjs",
    "check:dist": "node scripts/check_dist_clean.mjs",
    "check:source-provenance": "node scripts/check_source_provenance.mjs",
    "compare:v9-bundles": "tsx --no-warnings=ExperimentalWarning scripts/compare_v9_bundles.ts",
    "dev": "tsx --env-file=.env --no-warnings=ExperimentalWarning src/index.ts",
    "dev:watch": "tsx watch --no-warnings=ExperimentalWarning src/index.ts",
    "start": "node dist/index.js",
    "init-chronicle": "tsx --no-warnings=ExperimentalWarning scripts/init_chronicle.ts",
    "report:v9": "tsx --no-warnings=ExperimentalWarning scripts/report_v9_runs.ts",
    "test:governance-replay": "node --import tsx --no-warnings=ExperimentalWarning scripts/test_governance_proof_replay.ts",
    "test:live-governance": "node scripts/run_live_governance_tests.mjs",
    "test:live-governance:required": "node scripts/run_live_governance_tests.mjs --required-deepseek",
    "test:live-governance:breadth": "tsx --no-warnings=ExperimentalWarning scripts/live_governance_breadth.ts",
    "test:live-subagents:readonly:required": "tsx --no-warnings=ExperimentalWarning scripts/live_subagents_readonly_required.ts",
    "test:local-stack-parity": "tsx --no-warnings=ExperimentalWarning scripts/test_local_stack_parity.ts",
    "reliability:matrix": "tsx --no-warnings=ExperimentalWarning scripts/live_cli_reliability_matrix.ts",
    "test": "npm run test:unit && npm run test:resolver && npm run test:pipeline-v9 && npm run test:mcp-adapter && npm run test:smoke-fixtures && npm run test:parity-audit && npm run test:otel-tracing && npm run test:android-warning-cleanup && npm run test:bounded-contract && npm run test:orchestrator-routing",
    "test:mcp-adapter": "tsx --no-warnings=ExperimentalWarning scripts/test_mcp_adapter.ts",
    "test:otel-tracing": "tsx --no-warnings=ExperimentalWarning scripts/test_otel_tracing.ts",
    "test:otel-tracing:live": "tsx --no-warnings=ExperimentalWarning scripts/test_otel_tracing.ts --live",
    "test:orchestrator-routing": "tsx --no-warnings=ExperimentalWarning scripts/test_orchestrator_routing.ts",
    "test:manifest-preview": "tsx --no-warnings=ExperimentalWarning scripts/test_manifest_preview.ts",
    "test:android-warning-cleanup": "tsx --no-warnings=ExperimentalWarning scripts/test_android_warning_cleanup.ts",
    "test:bounded-contract": "tsx --no-warnings=ExperimentalWarning scripts/test_bounded_contract_normalization.ts",
    "test:pipeline-v9": "tsx --no-warnings=ExperimentalWarning scripts/test_pipeline_v9.ts",
    "test:pipeline-v9:live": "tsx --no-warnings=ExperimentalWarning scripts/test_pipeline_v9.ts --live",
    "test:pipeline-integration": "tsx --no-warnings=ExperimentalWarning --test src/pipeline.integration.test.ts",
    "test:lite-gate": "tsx --no-warnings=ExperimentalWarning --test src/agent/**/*.test.ts src/cli/*.test.ts src/commands/*.test.ts src/pipeline/*.test.ts src/services/askAnswer.test.ts src/services/checkpoints.test.ts src/services/ciReview.test.ts src/services/lite*.test.ts src/services/parityCorpus.test.ts src/services/smallFix.test.ts src/services/targetResolver.test.ts",
    "test:lite-parallel-review": "tsx --no-warnings=ExperimentalWarning scripts/run_lite_parallel_review.ts",
    "test:lite-worker-loop": "tsx --no-warnings=ExperimentalWarning scripts/run_lite_worker_loop.ts",
    "test:resolver": "tsx --no-warnings=ExperimentalWarning scripts/test_resolver.ts",
    "test:smoke-fixtures": "tsx --no-warnings=ExperimentalWarning scripts/test_smoke_fixtures.ts",
    "test:parity-audit": "tsx --no-warnings=ExperimentalWarning scripts/parity_audit_montecarlo.ts",
    "test:lite-trust-demo": "tsx --no-warnings=ExperimentalWarning scripts/run_lite_trust_demo.ts",
    "test:live-small-fix:optional": "tsx --no-warnings=ExperimentalWarning scripts/run_live_small_fix_optional.ts",
    "test:bounded-deep-probe:optional": "tsx --no-warnings=ExperimentalWarning scripts/run_bounded_deep_probe.ts",
    "test:live-daily-fix:optional": "npm run test:live-small-fix:optional",
    "test:u0-baseline": "tsx --no-warnings=ExperimentalWarning --test src/agent/observabilityAcceptance.test.ts src/agent/implementorScorecard.test.ts",
    "evidence:scorecard": "node dist/index.js evidence scorecard",
    "test:tier0": "tsx --no-warnings=ExperimentalWarning --test src/agent/chatGate.test.ts src/agent/chatEngineStall.test.ts src/config/chatEngineLimits.test.ts src/agent/repoMapPreamble.test.ts src/agent/chatCompaction.test.ts",
    "test:unit": "tsx --no-warnings=ExperimentalWarning --test src/*.test.ts src/agent/*.test.ts src/agent/lanes/*.test.ts src/cli/*.test.ts src/commands/*.test.ts src/config/*.test.ts src/evidence/*.test.ts src/interactive/execution/*.test.ts src/pipeline/*.test.ts src/protocol/**/*.test.ts src/runners/*.test.ts src/runtime/*.test.ts src/schemas/*.test.ts src/services/**/*.test.ts src/stages/*.test.ts src/tools/*.test.ts src/ui/*.test.ts src/utils/*.test.ts",
    "test:proof-learning": "tsx --no-warnings=ExperimentalWarning --test src/services/proof.test.ts src/services/learning.test.ts src/commands/userCommandSmoke.test.ts",
    "test:prompts": "npx promptfoo eval --config promptfoo/config.yaml",
    "test:prompts:ci": "npx promptfoo eval --config promptfoo/config.yaml --output promptfoo/results.json --max-concurrency 3",
    "test:schema-failures:unit": "tsx --no-warnings=ExperimentalWarning --test src/schemas/agentContracts.test.ts src/services/schemaFailureLedger.test.ts src/execute.reliabilityRepairProof.test.ts src/execute.schemaFailureLedger.test.ts src/runners/deepSeekApi.test.ts src/runners/deepInfraApi.test.ts",
    "test:ui": "tsx --no-warnings=ExperimentalWarning --test src/ui/**/*.test.ts",
    "test:ui:coverage": "tsx --no-warnings=ExperimentalWarning --experimental-test-coverage --test src/ui/**/*.test.ts",
    "test:ui:update": "UPDATE_SNAPSHOTS=1 npm run test:ui",
    "test:contrast": "tsx --no-warnings=ExperimentalWarning --test src/ui/contrast.test.ts",
    "knip": "knip",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run check:source-provenance && npm run check:dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "groq-sdk": "^0.37.0",
    "log-update": "^8.0.0",
    "marked": "^18.0.5",
    "minisearch": "^7.2.0",
    "nucleo-matcher-wasm": "^0.4.0",
    "sqlite-vec": "^0.1.9",
    "string-width": "^8.2.0",
    "supports-terminal-graphics": "^0.1.0",
    "wrap-ansi": "^10.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "js-tiktoken": "^1.0.21",
    "knip": "^6.17.1",
    "prettier": "^3.8.5",
    "promptfoo": "^0.121.17",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
